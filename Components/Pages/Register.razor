@page "/register"
@layout AuthLayout
@rendermode InteractiveServer

@using app_nutri.Models
@using app_nutri.Services

@inject AuthService AuthService
@inject NavigationManager NavigationManager

<div class="auth-page">
   
       

    <div class="auth-card">
        <div class="card-header-custom">
            <div class="icon-circle">👩‍🍳</div>
            <h3>Inscription</h3>
            <p>Rejoignez la communauté des recettes</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert-custom">
                @errorMessage
            </div>
        }

        <div class="form-group-custom">
            <label>Nom complet</label>
            <input class="form-control-custom"
                   placeholder="Votre nom complet"
                   @bind="fullName" />
        </div>

        <div class="form-group-custom">
            <label>Email</label>
            <input class="form-control-custom"
                   placeholder="exemple@email.com"
                   @bind="email" />
        </div>

        <div class="form-group-custom">
            <label>Mot de passe</label>
            <input type="password"
                   class="form-control-custom"
                   placeholder="Choisir un mot de passe"
                   @bind="password" />
        </div>

        <button class="btn-auth" @onclick="HandleRegister">
            Créer mon compte
        </button>

        <div class="auth-footer">
            <span>Déjà un compte ?</span>
            <a href="/login">Se connecter</a>
        </div>
    </div>
</div>

@code {
    private string fullName = string.Empty;
    private string email = string.Empty;
    private string password = string.Empty;
    private string errorMessage = string.Empty;

    private async Task HandleRegister()
    {
        try
        {
            errorMessage = string.Empty;

            await AuthService.RegisterAsync(fullName, email, password);

            NavigationManager.NavigateTo("/user/home");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}