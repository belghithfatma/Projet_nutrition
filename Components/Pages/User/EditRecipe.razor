@page "/edit-recipe/{Id:int}"
@rendermode InteractiveServer

@inject RecipeService RecipeService
@inject IngredientService IngredientService
@inject NavigationManager Navigation

<h1>Edit Recipe</h1>
@if (recipe is null) { <p>Recipe not found.</p> }
else
{
<div class="form-card">
    <label>Title</label><input @bind="recipe.Title" />
    <label>Description</label><textarea @bind="recipe.Description"></textarea>
    <label>Category</label><select @bind="recipe.Category"><option>Petit-déjeuner</option><option>Déjeuner</option><option>Dîner</option><option>Dessert</option></select>
    <label>Cuisine Type</label><select @bind="recipe.CuisineType"><option>Tunisienne</option><option>Française</option><option>Italienne</option><option>Méditerranéenne</option></select>
    <label>Number of Persons</label><input type="number" @bind="recipe.Servings" />
    <label>Image URL</label><input @bind="recipe.ImageUrl" />
    <h3>Ingredients</h3>
    @foreach (var row in selectedIngredients)
    {
        <div class="rowx"><select @bind="row.IngredientId"><option value="0">Select ingredient</option>@foreach (var i in ingredients){<option value="@i.Id">@i.Name</option>}</select><input type="number" step="0.1" @bind="row.Quantity" /></div>
    }
    <button class="secondary" @onclick="AddIngredientRow">+ Add Ingredient</button>
    <button class="primary" @onclick="SaveChanges">Save Changes</button>
</div>
}
@code {
    [Parameter] public int Id { get; set; }
    private Recipe? recipe;
    private List<Ingredient> ingredients = new();
    private List<RecipeIngredient> selectedIngredients = new();
    protected override async Task OnInitializedAsync(){ ingredients = await IngredientService.GetAllAsync(); recipe = await RecipeService.GetByIdAsync(Id); selectedIngredients = recipe?.RecipeIngredients.Select(x => new RecipeIngredient{IngredientId=x.IngredientId, Quantity=x.Quantity}).ToList() ?? new(); if(!selectedIngredients.Any()) selectedIngredients.Add(new RecipeIngredient{Quantity=1}); }
    private void AddIngredientRow() => selectedIngredients.Add(new RecipeIngredient { Quantity = 1 });
    private async Task SaveChanges(){ if(recipe is null) return; await RecipeService.UpdateAsync(recipe, selectedIngredients.Where(x=>x.IngredientId>0 && x.Quantity>0).ToList()); Navigation.NavigateTo("/recipes"); }
}
<style>.form-card{max-width:760px;background:white;padding:35px;border-radius:24px;box-shadow:0 8px 25px #0002;display:flex;flex-direction:column;gap:12px}input,select,textarea{padding:14px;border:0;border-radius:12px;background:#f5f5f5}.rowx{display:flex;gap:12px}.rowx select{flex:2}.rowx input{flex:1}.primary,.secondary{padding:14px;border:0;border-radius:12px;font-weight:700;cursor:pointer}.primary{background:#ffb703;color:white}.secondary{background:#eee}</style>
