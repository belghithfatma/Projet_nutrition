@page "/recipes"
@page "/"
@rendermode InteractiveServer

@using app_nutri.Models
@using app_nutri.Components.Shared
@using app_nutri.Services

@inject RecipeService RecipeService
@inject FavoriteService FavoriteService

<div class="recipes-page">

 

    <!-- Filters -->
    <div class="filters-bar">
        <div class="search-wrap">
            <span class="search-icon">🔍</span>
            <input placeholder="Rechercher une recette..."
                   @bind="searchText"
                   @bind:event="oninput" />
        </div>
        <select @bind="selectedCategory">
            <option value="">Toutes catégories</option>
            <option value="Petit-déjeuner"> Petit-déjeuner</option>
            <option value="Déjeuner">Déjeuner</option>
            <option value="Dîner"> Dîner</option>
            <option value="Dessert"> Dessert</option>
        </select>
        <select @bind="selectedCuisine">
            <option value="">Toutes cuisines</option>
            <option value="Tunisienne">🇹🇳 Tunisienne</option>
            <option value="Française">🇫🇷 Française</option>
            <option value="Italienne">🇮🇹 Italienne</option>
            <option value="Méditerranéenne">Méditerranéenne</option>
        </select>
        <div class="results-count">@FilteredRecipes.Count() recette(s)</div>
    </div>

    <!-- Grid -->
    <div class="recipes-grid">
        @if (loading)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>Chargement des recettes...</p>
            </div>
        }
        else if (FilteredRecipes.Any())
        {
            @foreach (var recipe in FilteredRecipes)
            {
                <RecipeCard Recipe="recipe" OnDelete="LoadRecipes" />
            }
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon"></div>
                <h3>Aucune recette trouvée</h3>
                <p>Modifiez vos filtres ou créez votre première recette !</p>
                <a href="/create-recipe" class="btn-create-empty">+ Créer une recette</a>
            </div>
        }
    </div>

</div>

@code {
    private List<Recipe> recipes = new();
    private bool loading = true;
    private string searchText = "";
    private string selectedCategory = "";
    private string selectedCuisine = "";

    protected override async Task OnInitializedAsync() => await LoadRecipes();

    private async Task LoadRecipes()
    {
        loading = true;
        recipes = await RecipeService.GetAllAsync();
        loading = false;
        StateHasChanged();
    }

    private IEnumerable<Recipe> FilteredRecipes
    {
        get
        {
            IEnumerable<Recipe> query = recipes;
            if (!string.IsNullOrWhiteSpace(searchText))
                query = query.Where(r =>
                    r.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    r.Description.Contains(searchText, StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrWhiteSpace(selectedCategory))
                query = query.Where(r => r.Category == selectedCategory);
            if (!string.IsNullOrWhiteSpace(selectedCuisine))
                query = query.Where(r => r.CuisineType == selectedCuisine);
            return query.ToList();
        }
    }
}

<style>

.recipes-page {
    padding: 36px 40px;
    background: linear-gradient(160deg, #f5f9ee 0%, #edf5e1 50%, #f8faf2 100%);
    min-height: 100vh;
    font-family: 'Helvetica Neue', sans-serif;
}

/* Hero */
.recipes-hero {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(255,255,255,0.6);
    backdrop-filter: blur(14px);
    border-radius: 28px;
    padding: 36px 40px;
    margin-bottom: 32px;
    border: 1px solid rgba(120,180,60,0.18);
    box-shadow: 0 8px 32px rgba(80,140,40,0.08);
}

.hero-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(120,180,60,0.12);
    color: #5a8a30;
    font-size: 13px;
    font-weight: 700;
    padding: 6px 16px;
    border-radius: 20px;
    border: 1px solid rgba(120,180,60,0.2);
    margin-bottom: 18px;
}

.hero-left h1 {
    font-size: 38px;
    font-weight: 900;
    color: #2d4a1e;
    line-height: 1.15;
    margin-bottom: 14px;
}

.hero-accent {
    background: linear-gradient(90deg, #6db33f, #a8d96a);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.hero-left p {
    color: #7a9e60;
    font-size: 15px;
    max-width: 420px;
    line-height: 1.6;
    margin-bottom: 20px;
}

.hero-icons {
    display: flex;
    gap: 12px;
}

.hero-icons span {
    background: white;
    font-size: 24px;
    width: 52px; height: 52px;
    border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 14px rgba(80,140,40,0.12);
    border: 1px solid rgba(120,180,60,0.15);
}

.btn-create {
    background: linear-gradient(135deg, #6db33f 0%, #8fca5a 100%);
    color: white;
    padding: 15px 28px;
    border-radius: 18px;
    font-weight: 800;
    font-size: 15px;
    text-decoration: none;
    box-shadow: 0 6px 20px rgba(100,180,40,0.3);
    transition: 0.25s;
    white-space: nowrap;
}

.btn-create:hover {
    transform: scale(1.05) translateY(-2px);
    box-shadow: 0 10px 30px rgba(100,180,40,0.38);
    color: white;
}

/* Filters */
.filters-bar {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 30px;
}

.search-wrap {
    position: relative;
    flex: 1;
    min-width: 220px;
}

.search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 15px;
}

.search-wrap input {
    width: 100%;
    padding: 13px 14px 13px 42px;
    border: 1.5px solid rgba(120,180,60,0.2);
    border-radius: 14px;
    background: rgba(255,255,255,0.8);
    backdrop-filter: blur(8px);
    font-size: 14px;
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.2s, box-shadow 0.2s;
}

.search-wrap input:focus {
    border-color: #6db33f;
    box-shadow: 0 0 0 3px rgba(109,179,63,0.12);
}

.filters-bar select {
    padding: 13px 16px;
    border: 1.5px solid rgba(120,180,60,0.2);
    border-radius: 14px;
    background: rgba(255,255,255,0.8);
    backdrop-filter: blur(8px);
    font-size: 14px;
    outline: none;
    cursor: pointer;
    min-width: 190px;
    transition: border-color 0.2s;
}

.filters-bar select:focus { border-color: #6db33f; }

.results-count {
    font-size: 13px;
    color: #9ab880;
    font-weight: 600;
    background: rgba(120,180,60,0.1);
    padding: 8px 16px;
    border-radius: 20px;
    white-space: nowrap;
}

/* Grid */
.recipes-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
}

/* Loading */
.loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    padding: 80px;
    color: #9ab880;
    width: 100%;
}

.spinner {
    width: 42px; height: 42px;
    border: 4px solid rgba(120,180,60,0.15);
    border-top-color: #6db33f;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}

@@keyframes spin { to { transform: rotate(360deg); } }

/* Empty */
.empty-state {
    width: 100%;
    padding: 70px 40px;
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(10px);
    border-radius: 24px;
    text-align: center;
    border: 1px solid rgba(120,180,60,0.15);
    box-shadow: 0 4px 20px rgba(80,140,40,0.07);
}

.empty-icon { font-size: 64px; margin-bottom: 16px; }

.empty-state h3 {
    font-size: 24px;
    font-weight: 800;
    color: #2d4a1e;
    margin-bottom: 8px;
}

.empty-state p { color: #9ab880; font-size: 15px; margin-bottom: 24px; }

.btn-create-empty {
    display: inline-block;
    background: linear-gradient(135deg, #6db33f, #8fca5a);
    color: white;
    padding: 13px 26px;
    border-radius: 16px;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(100,180,40,0.25);
    transition: 0.2s;
}

.btn-create-empty:hover { opacity: 0.88; transform: scale(1.04); color: white; }

</style>