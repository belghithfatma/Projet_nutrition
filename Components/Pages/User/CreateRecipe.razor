@page "/create-recipe"
@rendermode InteractiveServer

@inject RecipeService RecipeService
@inject IngredientService IngredientService
@inject NavigationManager Navigation

<h1>Create New Recipe</h1>
<div class="form-card">
    <label>Title</label><input @bind="recipe.Title" />
    <label>Description</label><textarea @bind="recipe.Description"></textarea>
    <label>Category</label><select @bind="recipe.Category"><option>Petit-déjeuner</option><option>Déjeuner</option><option>Dîner</option><option>Dessert</option></select>
    <label>Cuisine Type</label><select @bind="recipe.CuisineType"><option>Tunisienne</option><option>Française</option><option>Italienne</option><option>Méditerranéenne</option></select>
    <label>Number of Persons</label><input type="number" @bind="recipe.Servings" />
    <label>Image URL</label><input @bind="recipe.ImageUrl" />

    <h3>Ingredients</h3>
    @foreach (var row in selectedIngredients)
    {
        <div class="rowx">
            <select @bind="row.IngredientId">
                <option value="0">Select ingredient</option>
                @foreach (var i in ingredients) { <option value="@i.Id">@i.Name (@i.Unit - @i.CaloriesPerUnit kcal)</option> }
            </select>
            <input type="number" step="0.1" @bind="row.Quantity" placeholder="Quantity" />
        </div>
    }
    <button class="secondary" @onclick="AddIngredientRow">+ Add Ingredient</button>
    <button class="primary" @onclick="SaveRecipe">Create Recipe</button>
</div>

@code {
    private Recipe recipe = new() { AuthorName = "Fatma", Servings = 1 };
    private List<Ingredient> ingredients = new();
    private List<RecipeIngredient> selectedIngredients = new() { new RecipeIngredient { Quantity = 1 } };
    protected override async Task OnInitializedAsync() => ingredients = await IngredientService.GetAllAsync();
    private void AddIngredientRow() => selectedIngredients.Add(new RecipeIngredient { Quantity = 1 });
    private async Task SaveRecipe()
    {
        var rows = selectedIngredients.Where(x => x.IngredientId > 0 && x.Quantity > 0).ToList();
        await RecipeService.AddAsync(recipe, rows);
       Navigation.NavigateTo("/recipes", true);
    }
}
<style>.form-card{max-width:760px;background:white;padding:35px;border-radius:24px;box-shadow:0 8px 25px #0002;display:flex;flex-direction:column;gap:12px}input,select,textarea{padding:14px;border:0;border-radius:12px;background:#f5f5f5}.rowx{display:flex;gap:12px}.rowx select{flex:2}.rowx input{flex:1}.primary,.secondary{padding:14px;border:0;border-radius:12px;font-weight:700;cursor:pointer}.primary{background:#6c63ff;color:white}.secondary{background:#eee}</style>
