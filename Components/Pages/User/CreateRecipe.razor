@page "/create-recipe"
@rendermode InteractiveServer

@inject RecipeService RecipeService
@inject IngredientService IngredientService
@inject NavigationManager Navigation

<div class="create-page">

    <!-- Header -->
    <div class="create-header">
        <h1>Créer une <span class="accent">recette</span></h1>
    </div>

    <div class="create-layout">

        <!-- Left : Infos principales -->
        <div class="form-card main-card">

            <div class="section-title"> Informations générales</div>

            <div class="field-group">
                <label>Titre de la recette</label>
                <input placeholder="Ex: Couscous tunisien traditionnel..." @bind="recipe.Title" />
            </div>

            <div class="field-group">
                <label>Description</label>
                <textarea placeholder="Décrivez votre recette en quelques mots..." @bind="recipe.Description" rows="4"></textarea>
            </div>

            <div class="field-row">
                <div class="field-group">
                    <label>Catégorie</label>
                    <select @bind="recipe.Category">
                        <option value="">Choisir...</option>
                        <option value="Petit-déjeuner"> Petit-déjeuner</option>
                        <option value="Déjeuner"> Déjeuner</option>
                        <option value="Dîner"> Dîner</option>
                        <option value="Dessert"> Dessert</option>
                    </select>
                </div>

                <div class="field-group">
                    <label>Type de cuisine</label>
                    <select @bind="recipe.CuisineType">
                        <option value="">Choisir...</option>
                        <option value="Tunisienne"> Tunisienne</option>
                        <option value="Française"> Française</option>
                        <option value="Italienne"> Italienne</option>
                        <option value="Méditerranéenne"> Méditerranéenne</option>
                    </select>
                </div>
            </div>

            <div class="field-row">
                <div class="field-group">
                    <label> Nombre de personnes</label>
                    <input type="number" min="1" placeholder="Ex: 4" @bind="recipe.Servings" />
                </div>

                <div class="field-group">
                    <label> URL de l'image</label>
                    <input placeholder="https://..." @bind="recipe.ImageUrl" />
                </div>
            </div>

            <!-- Preview image -->
            @if (!string.IsNullOrWhiteSpace(recipe.ImageUrl))
            {
                <div class="img-preview">
                    <img src="@recipe.ImageUrl" alt="preview" />
                    <span class="img-preview-label">Aperçu de l'image</span>
                </div>
            }

        </div>

        <!-- Right : Ingrédients -->
        <div class="form-card ingredients-card">

            <div class="section-title"> Ingrédients</div>

            <div class="ingredients-list">
                @foreach (var (row, index) in selectedIngredients.Select((r, i) => (r, i)))
                {
                    <div class="ingredient-row">
                        <span class="row-num">@(index + 1)</span>
                        <select @bind="row.IngredientId" class="ing-select">
                            <option value="0">Sélectionner...</option>
                            @foreach (var ing in ingredients)
                            {
                                <option value="@ing.Id">@ing.Name (@ing.Unit — @ing.CaloriesPerUnit kcal)</option>
                            }
                        </select>
                        <input type="number"
                               step="0.1"
                               min="0"
                               placeholder="Qté"
                               @bind="row.Quantity"
                               class="ing-qty" />
                        @if (selectedIngredients.Count > 1)
                        {
                            <button class="btn-remove" @onclick="() => RemoveRow(row)" title="Supprimer">✕</button>
                        }
                    </div>
                }
            </div>

            <button class="btn-add-ing" @onclick="AddIngredientRow">
                + Ajouter un ingrédient
            </button>

            <!-- Calories preview -->
            @if (selectedIngredients.Any(r => r.IngredientId > 0 && r.Quantity > 0))
            {
                <div class="calories-preview">
                    <div class="cal-row">
                        <span>🔥 Calories totales</span>
                        <strong>@CaloriesTotal.ToString("0") kcal</strong>
                    </div>
                    @if (recipe.Servings > 0)
                    {
                        <div class="cal-row">
                            <span> Par personne (@recipe.Servings pers.)</span>
                            <strong>@(CaloriesTotal / recipe.Servings).ToString("0") kcal</strong>
                        </div>
                    }
                </div>
            }

        </div>

    </div>

    <!-- Submit -->
    <div class="form-actions">
        <a href="/recipes" class="btn-cancel">← Annuler</a>
        <button class="btn-submit" @onclick="SaveRecipe">
             Créer la recette
        </button>
    </div>

</div>

@code {
    private Recipe recipe = new() { AuthorName = "Fatma", Servings = 1 };
    private List<Ingredient> ingredients = new();
    private List<RecipeIngredient> selectedIngredients = new() { new RecipeIngredient { Quantity = 1 } };

    protected override async Task OnInitializedAsync()
        => ingredients = await IngredientService.GetAllAsync();

    private void AddIngredientRow()
        => selectedIngredients.Add(new RecipeIngredient { Quantity = 1 });

    private void RemoveRow(RecipeIngredient row)
        => selectedIngredients.Remove(row);

    private double CaloriesTotal => selectedIngredients
        .Where(r => r.IngredientId > 0 && r.Quantity > 0)
        .Sum(r =>
        {
            var ing = ingredients.FirstOrDefault(i => i.Id == r.IngredientId);
            return ing is not null ? ing.CaloriesPerUnit * r.Quantity : 0;
        });

    private async Task SaveRecipe()
    {
        var rows = selectedIngredients
            .Where(x => x.IngredientId > 0 && x.Quantity > 0)
            .ToList();
        await RecipeService.AddAsync(recipe, rows);
        Navigation.NavigateTo("/recipes", true);
    }
}

<style>

