@page "/recipe-details/{Id:int}"
@rendermode InteractiveServer

@inject RecipeService RecipeService
@inject ReviewService ReviewService

@if (recipe is null)
{
    <p>Recipe not found.</p>
}
else
{
    <div class="details-card">
        <img src="@Image" />
        <div class="content">
            <h1>@recipe.Title</h1>
            <p>@recipe.Description</p>
            <div class="tags"><span>@recipe.Category</span><span>@recipe.CuisineType</span></div>
            <div class="stats"><div>Total<br /><b>@total.ToString("0") kcal</b></div><div>Per person<br /><b>@perPerson.ToString("0") kcal</b></div><div>Persons<br /><b>@recipe.Servings</b></div></div>
            <h3>Ingredients</h3>
            <ul>@foreach (var ri in recipe.RecipeIngredients){<li>@ri.Ingredient?.Name - @ri.Quantity @ri.Ingredient?.Unit</li>}</ul>
            <h3>Reviews</h3>
            <div class="review-form"><input placeholder="Name" @bind="newReview.UserName" /><select @bind="newReview.Rating"><option value="1">1 ⭐</option><option value="2">2 ⭐</option><option value="3">3 ⭐</option><option value="4">4 ⭐</option><option value="5">5 ⭐</option></select><textarea placeholder="Comment" @bind="newReview.Comment"></textarea><button @onclick="AddReview">Add Review</button></div>
            @foreach (var r in reviews){<div class="review"><b>@r.UserName</b> - @Stars(r.Rating)<p>@r.Comment</p></div>}
        </div>
    </div>
}
@code {
    [Parameter] public int Id { get; set; }
    private Recipe? recipe;
    private List<Review> reviews = new();
    private Review newReview = new() { Rating = 5, UserName = "Guest" };
    private double total, perPerson;
    private string Image => string.IsNullOrWhiteSpace(recipe?.ImageUrl) ? "https://images.unsplash.com/photo-1546069901-ba9599a7e63c" : recipe.ImageUrl;
    protected override async Task OnInitializedAsync() => await Load();
    private async Task Load(){ recipe = await RecipeService.GetByIdAsync(Id); if(recipe is not null){ total = RecipeService.GetTotalCalories(recipe); perPerson = RecipeService.GetCaloriesPerPerson(recipe); reviews = await ReviewService.GetByRecipeAsync(Id); newReview.RecipeId = Id; } }
    private async Task AddReview(){ if(string.IsNullOrWhiteSpace(newReview.Comment)) return; await ReviewService.AddAsync(newReview); newReview = new Review{RecipeId=Id, Rating=5, UserName="Guest"}; await Load(); }
    private static string Stars(int rating) => new string('⭐', Math.Clamp(rating,1,5));
}
<style>.details-card{max-width:1000px;background:white;border-radius:28px;overflow:hidden;box-shadow:0 8px 25px #0002}.details-card>img{width:100%;height:380px;object-fit:cover}.content{padding:35px}.tags{display:flex;gap:12px}.tags span{background:#f1f1f1;padding:8px 14px;border-radius:20px}.stats{display:flex;gap:16px;margin:24px 0}.stats div{flex:1;background:#f8f8f8;padding:20px;border-radius:18px;text-align:center}.review-form{display:grid;gap:10px}.review-form input,.review-form select,.review-form textarea{padding:12px;border:0;border-radius:12px;background:#f5f5f5}.review-form button{padding:12px;border:0;border-radius:12px;background:#6c63ff;color:white}.review{background:#fafafa;padding:14px;border-radius:14px;margin-top:10px}</style>
