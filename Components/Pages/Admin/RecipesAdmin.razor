@page "/admin/recipes"
@rendermode InteractiveServer

@using app_nutri.Models
@using app_nutri.Services

@inject RecipeService RecipeService

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<div class="recipes-admin-page">


    <div class="top-section">


        <div class="stats-card">

            <div class="stats-icon">
                <i class="fa-solid fa-bowl-food"></i>
            </div>

            <span>Total Recipes</span>

            <h2>@recipes.Count</h2>

        </div>

    </div>



    <div class="recipes-grid">

        @foreach(var recipe in recipes)
        {
            <div class="recipe-card">

                <img src="@recipe.ImageUrl"
                     alt="@recipe.Title" />

                <div class="recipe-content">

        

                    <div class="recipe-top">

                        <span class="category">
                            @recipe.Category
                        </span>

                        <span class="cuisine">
                            @recipe.CuisineType
                        </span>

                    </div>


                    <h3>@recipe.Title</h3>


                    <p class="description">
                        @recipe.Description
                    </p>



                    <div class="recipe-info">

                        <div>
                            <i class="fa-solid fa-user"></i>

                            @recipe.AuthorName
                        </div>

                        <div>
                            <i class="fa-solid fa-fire"></i>

                            @recipe.RecipeIngredients.Sum(x =>
                            x.Quantity * x.Ingredient.CaloriesPerUnit)

                            kcal
                        </div>

                    </div>

                    <!-- FOOTER -->

                    <div class="recipe-footer">

                        <span>
                            <i class="fa-solid fa-users"></i>

                            @recipe.Servings persons
                        </span>

                        <div class="recipe-date">

                            <i class="fa-solid fa-calendar"></i>

                            @recipe.CreatedAt.ToString("dd MMM yyyy")

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>

@code {

    private List<Recipe> recipes = new();

    protected override async Task OnInitializedAsync()
    {
        recipes =
            await RecipeService
            .GetAllRecipesForAdminAsync();
    }
}

<style>

.recipes-admin-page{

    padding:40px;

    min-height:100vh;

    background:
    radial-gradient(circle at top left,#eef7d8,#f8f9f3 40%),
    radial-gradient(circle at bottom right,#fff2d5,#f8f9f3 40%);

    font-family:'Segoe UI',sans-serif;
}

/* HEADER */

.top-section{

    display:flex;

    justify-content:space-between;

    align-items:center;

    margin-bottom:50px;
}

.badge{

    display:inline-block;

    background:#edf7d7;

    color:#72912d;

    padding:10px 18px;

    border-radius:50px;

    font-weight:700;

    margin-bottom:22px;
}

.top-section h1{

    font-size:64px;

    font-weight:900;

    color:#1f3115;

    margin-bottom:12px;

    line-height:1.1;
}

.top-section p{

    color:#697561;

    font-size:18px;

    max-width:600px;

    line-height:1.8;
}

/* STATS */

.stats-card{

    width:230px;
    height:230px;

    border-radius:42px;

    background:white;

    display:flex;

    flex-direction:column;

    align-items:center;

    justify-content:center;

    box-shadow:
    0 20px 50px rgba(0,0,0,0.08);

    position:relative;

    overflow:hidden;
}

.stats-card::before{

    content:'';

    position:absolute;

    width:280px;
    height:280px;

    background:
    linear-gradient(
    135deg,
    rgba(164,198,58,0.15),
    rgba(255,194,71,0.15));

    border-radius:50%;

    top:-140px;
    right:-100px;
}

.stats-icon{

    width:80px;
    height:80px;

    border-radius:26px;

    background:
    linear-gradient(
    135deg,
    #a4c63a,
    #ffc247);

    color:white;

    display:flex;

    align-items:center;

    justify-content:center;

    font-size:32px;

    margin-bottom:20px;

    box-shadow:
    0 15px 35px rgba(164,198,58,0.35);
}

.stats-card span{

    color:#79856d;

    font-size:15px;
}

.stats-card h2{

    font-size:58px;

    color:#203515;

    margin-top:10px;
}

/* GRID */

.recipes-grid{

    display:grid;

    grid-template-columns:
    repeat(auto-fill,minmax(370px,1fr));

    gap:35px;
}

/* CARD */

.recipe-card{

    background:white;

    border-radius:38px;

    overflow:hidden;

    box-shadow:
    0 20px 45px rgba(0,0,0,0.07);

    transition:0.4s;

    position:relative;
}

.recipe-card:hover{

    transform:
    translateY(-8px)
    scale(1.015);

    box-shadow:
    0 30px 60px rgba(0,0,0,0.1);
}

/* IMAGE */

.recipe-card img{

    width:100%;

    height:270px;

    object-fit:cover;
}

/* CONTENT */

.recipe-content{

    padding:28px;
}

/* TOP TAGS */

.recipe-top{

    display:flex;

    justify-content:space-between;

    margin-bottom:20px;
}

.category,
.cuisine{

    padding:10px 16px;

    border-radius:50px;

    font-size:13px;

    font-weight:800;

    letter-spacing:0.3px;
}

.category{

    background:#eef7d8;

    color:#72912d;
}

.cuisine{

    background:#fff1d6;

    color:#d89600;
}

/* TITLE */

.recipe-content h3{

    font-size:30px;

    font-weight:900;

    color:#1f3115;

    margin-bottom:16px;
}

/* DESCRIPTION */

.description{

    color:#707b68;

    line-height:1.8;

    margin-bottom:26px;

    font-size:15px;
}

/* INFO */

.recipe-info{

    display:flex;

    justify-content:space-between;

    margin-bottom:28px;

    color:#607055;

    font-weight:700;

    font-size:15px;
}

.recipe-info div{

    display:flex;

    align-items:center;

    gap:10px;
}

/* FOOTER */

.recipe-footer{

    display:flex;

    justify-content:space-between;

    align-items:center;

    padding-top:18px;

    border-top:1px solid #f1f1f1;
}

.recipe-footer span{

    display:flex;

    align-items:center;

    gap:10px;

    color:#5d6d51;

    font-weight:700;
}

/* DATE */

.recipe-date{

    display:flex;

    align-items:center;

    gap:10px;

    color:#7c8972;

    font-weight:700;

    font-size:14px;
}

/* RESPONSIVE */

@@media(max-width:1000px){

    .top-section{

        flex-direction:column;

        align-items:flex-start;

        gap:30px;
    }

    .top-section h1{

        font-size:48px;
    }
}

@@media(max-width:768px){

    .recipes-admin-page{

        padding:25px;
    }

    .recipes-grid{

        grid-template-columns:1fr;
    }

    .top-section h1{

        font-size:40px;
    }

    .stats-card{

        width:100%;
        height:200px;
    }
}

</style>