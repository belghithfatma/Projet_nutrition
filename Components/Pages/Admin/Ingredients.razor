@page "/admin/ingredients"
@rendermode InteractiveServer

@inject IngredientService IngredientService

<div class="ingredients-page">

    <div class="form-card">

        <div class="form-title">

            <h3>
                @(ingredient.Id == 0
                    ? "Add New Ingredient"
                    : "Update Ingredient")
            </h3>

            <p>Fill ingredient nutritional information</p>

        </div>

        <div class="form-grid">

            <div class="input-group">

                <label>Name</label>

                <input type="text"
                       placeholder="Ex: Mozzarella"
                       @bind="ingredient.Name"
                       @bind:event="oninput" />

            </div>

            <div class="input-group">

                <label>Unit</label>

                <input type="text"
                       placeholder="Ex: 100 g"
                       @bind="ingredient.Unit"
                       @bind:event="oninput" />

            </div>

            <div class="input-group">

                <label>Calories</label>

                <input type="number"
                       step="0.1"
                       placeholder="Calories"
                       @bind="ingredient.CaloriesPerUnit"
                       @bind:event="oninput" />

            </div>

        </div>

        <button class="save-btn"
                @onclick="SaveIngredient">

            @(ingredient.Id == 0
                ? "＋ Add Ingredient"
                : "✎ Update Ingredient")

        </button>

    </div>

    <div class="table-card">

        <div class="table-top">

            <div>
                <h3>Ingredients List</h3>
                <p>@ingredients.Count ingredients available</p>
            </div>

        </div>

        <table>

            <thead>
                <tr>
                    <th>Ingredient</th>
                    <th>Unit</th>
                    <th>Calories</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var i in ingredients)
                {
                    <tr>

                        <td>

                            <div class="ingredient-cell">
<div class="ingredient-avatar">
    @(string.IsNullOrWhiteSpace(i.Name)
        ? "?"
        : i.Name.Substring(0,1).ToUpper())
</div>

                                <div>
                                    <strong>@i.Name</strong>
                                </div>

                            </div>

                        </td>

                        <td>

                            <span class="unit-badge">
                                @i.Unit
                            </span>

                        </td>

                        <td>

                            <span class="calorie-badge">
                                🔥 @i.CaloriesPerUnit kcal
                            </span>

                        </td>

                        <td>

                            <div class="actions">

                                <button class="edit-btn"
                                        @onclick="() => EditIngredient(i)">

                                    Edit

                                </button>

                                <button class="delete-btn"
                                        @onclick="() => DeleteIngredient(i.Id)">

                                    Delete

                                </button>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

@code {

    private List<Ingredient> ingredients = new();

    private Ingredient ingredient = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadIngredients();
    }

    private async Task LoadIngredients()
    {
        ingredients = await IngredientService.GetAllAsync();
    }

    private void EditIngredient(Ingredient i)
    {
        ingredient = new Ingredient
        {
            Id = i.Id,
            Name = i.Name,
            Unit = i.Unit,
            CaloriesPerUnit = i.CaloriesPerUnit
        };

        StateHasChanged();
    }

    private async Task SaveIngredient()
    {
        if (ingredient.Id == 0)
        {
            await IngredientService.AddAsync(ingredient);
        }
        else
        {
            await IngredientService.UpdateAsync(ingredient);
        }

        ingredient = new Ingredient();

        await LoadIngredients();

        StateHasChanged();
    }

    // DELETE
    private async Task DeleteIngredient(int id)
    {
        await IngredientService.DeleteAsync(id);

        await LoadIngredients();
    }

}

<style>

*{
    font-family:'Segoe UI',sans-serif;
}

.ingredients-page{
    min-height:100vh;
    padding:40px;
    background:
    linear-gradient(135deg,#f7f9f2,#eef3e3);
}

/* HERO */

.hero-section{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:35px;
}

.hero-section h1{
    font-size:48px;
    font-weight:900;
    color:#1f2f18;
    margin-bottom:10px;
}

.hero-section p{
    color:#7a8571;
    font-size:16px;
}

.hero-stats{
    display:flex;
    gap:20px;
}

.stat-card{
    width:180px;
    padding:25px;
    border-radius:28px;

    background:rgba(255,255,255,0.7);

    backdrop-filter:blur(12px);

    box-shadow:
    0 10px 30px rgba(0,0,0,0.08);

    text-align:center;
}

.stat-card span{
    color:#7e8975;
    font-size:14px;
}

.stat-card h2{
    margin-top:10px;
    font-size:48px;
    color:#93b631;
}

/* FORM */

.form-card{
    background:white;
    border-radius:35px;
    padding:35px;
    margin-bottom:35px;

    box-shadow:
    0 10px 35px rgba(0,0,0,0.06);
}

.form-title{
    margin-bottom:30px;
}

.form-title h3{
    font-size:28px;
    color:#22301c;
}

.form-title p{
    color:#7d8475;
    margin-top:6px;
}

.form-grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:25px;
}

.input-group{
    display:flex;
    flex-direction:column;
}

.input-group label{
    margin-bottom:10px;
    font-weight:700;
    color:#2c3b26;
}

.input-group input{

    border:none;
    outline:none;

    background:#f4f7ef;

    padding:18px;

    border-radius:18px;

    transition:0.3s;

    font-size:15px;
}

.input-group input:focus{

    background:white;

    box-shadow:
    0 0 0 4px rgba(147,182,49,0.15);

}

.save-btn{

    margin-top:30px;

    border:none;

    background:
    linear-gradient(135deg,#9bc53d,#c8a93d);

    color:white;

    padding:18px 28px;

    border-radius:18px;

    font-weight:800;

    font-size:15px;

    cursor:pointer;

    transition:0.3s;

    box-shadow:
    0 10px 25px rgba(155,197,61,0.3);

}

.save-btn:hover{

    transform:
    translateY(-3px)
    scale(1.02);

}

/* TABLE */

.table-card{

    background:white;

    border-radius:35px;

    overflow:hidden;

    box-shadow:
    0 10px 35px rgba(0,0,0,0.06);

}

.table-top{

    padding:30px;

    border-bottom:
    1px solid #edf0e7;
}

.table-top h3{

    font-size:28px;

    color:#1e2c18;
}

.table-top p{

    margin-top:6px;

    color:#7e8778;
}

table{

    width:100%;

    border-collapse:collapse;
}

th{

    background:#f8faf5;

    padding:22px;

    text-align:left;

    color:#7d8775;

    font-size:14px;

    font-weight:700;
}

td{

    padding:22px;

    border-top:
    1px solid #f1f3ed;
}

tr{

    transition:0.2s;
}

tr:hover{

    background:#fbfcf8;
}

.ingredient-cell{

    display:flex;

    align-items:center;

    gap:15px;
}

.ingredient-avatar{

    width:45px;
    height:45px;

    border-radius:50%;

    background:
    linear-gradient(135deg,#9bc53d,#d4b03f);

    display:flex;
    align-items:center;
    justify-content:center;

    color:white;

    font-weight:800;
}

.unit-badge{

    background:#f1f5ea;

    color:#6f7f5d;

    padding:8px 15px;

    border-radius:30px;

    font-weight:700;
}

.calorie-badge{

    background:#eef7dc;

    color:#7da028;

    padding:10px 16px;

    border-radius:30px;

    font-weight:800;
}

.actions{

    display:flex;
    gap:10px;
}

.edit-btn{

    border:none;

    background:#95be2f;

    color:white;

    padding:11px 18px;

    border-radius:14px;

    cursor:pointer;

    font-weight:700;

    transition:0.3s;
}

.edit-btn:hover{

    transform:translateY(-2px);

    background:#7ea323;
}

.delete-btn{

    border:none;

    background:#ff5f5f;

    color:white;

    padding:11px 18px;

    border-radius:14px;

    cursor:pointer;

    font-weight:700;

    transition:0.3s;
}

.delete-btn:hover{

    transform:translateY(-2px);

    background:#ef4444;
}

/* RESPONSIVE */

@@media(max-width:1100px){

    .form-grid{
        grid-template-columns:1fr;
    }

    .hero-section{
        flex-direction:column;
        align-items:flex-start;
        gap:20px;
    }

    table{
        display:block;
        overflow-x:auto;
    }

}

</style>