@page "/login"
@layout AuthLayout
@rendermode InteractiveServer

@using app_nutri.Models
@using app_nutri.Services

@inject AuthService AuthService
@inject NavigationManager NavigationManager

<div class="auth-page">
  

    <div class="auth-card">
        <div class="card-header-custom">
            <div class="icon-circle">👩‍🍳</div>
            <h3>Connexion</h3>
            <p>Accédez à votre espace recette</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert-custom">
                @errorMessage
            </div>
        }

        <div class="form-group-custom">
            <label>Email</label>
            <input class="form-control-custom"
                   placeholder="exemple@email.com"
                   @bind="email" />
        </div>

        <div class="form-group-custom">
            <label>Mot de passe</label>
            <input type="password"
                   class="form-control-custom"
                   placeholder="Votre mot de passe"
                   @bind="password" />
        </div>

        <button class="btn-auth" @onclick="HandleLogin">
            Se connecter
        </button>

        <div class="auth-footer">
            <span>Pas encore de compte ?</span>
            <a href="/register">Créer un compte</a>
        </div>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private string errorMessage = string.Empty;

    private async Task HandleLogin()
    {
        errorMessage = string.Empty;

        var user = await AuthService.LoginAsync(email, password);

        if (user == null)
        {
            errorMessage = "Email ou mot de passe incorrect.";
            return;
        }

        if (user.Role == UserRole.Admin)
        {
            NavigationManager.NavigateTo("/admin/dashboard");
        }
        else
        {
            NavigationManager.NavigateTo("/recipes");
        }
    }
}