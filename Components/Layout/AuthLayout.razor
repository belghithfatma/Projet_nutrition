@inherits LayoutComponentBase

<style>
    .visitor-layout {
        min-height: 100vh;
        background: #fffaf0;
    }

    .visitor-navbar {
        height: 82px;
        padding: 0 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(255, 255, 255, 0.98);
        border-bottom: 1px solid rgba(111, 165, 54, 0.18);
        box-shadow: 0 10px 35px rgba(60, 80, 35, 0.08);
        position: sticky;
        top: 0;
        z-index: 9999;
    }

    .visitor-navbar a,
    .visitor-navbar a:visited,
    .visitor-navbar a:hover,
    .visitor-navbar a:active {
        text-decoration: none !important;
    }

    .visitor-brand {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .visitor-brand-icon {
        width: 48px;
        height: 48px;
        display: grid;
        place-items: center;
        border-radius: 16px;
        background: linear-gradient(135deg, #7caf36, #f4a442);
        box-shadow: 0 12px 28px rgba(111, 165, 54, 0.25);
        font-size: 23px;
    }

    .visitor-brand-name {
        color: #263a1f;
        font-size: 25px;
        font-weight: 900;
        letter-spacing: -0.5px;
    }

    .visitor-nav {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .visitor-nav-link {
        color: #405331 !important;
        font-weight: 800;
        font-size: 16px;
        padding: 11px 20px;
        border-radius: 999px;
        transition: all 0.2s ease;
    }

    .visitor-nav-link:hover {
        color: #6fa536 !important;
        background: #eef7df;
    }

    .visitor-nav-link.active {
        color: #6fa536 !important;
        background: #eef7df;
    }

    .visitor-nav-button {
        color: white !important;
        font-weight: 900;
        font-size: 16px;
        padding: 12px 26px;
        border-radius: 999px;
        background: linear-gradient(135deg, #6fa536, #f4a442);
        box-shadow: 0 14px 30px rgba(111, 165, 54, 0.28);
        transition: all 0.2s ease;
    }

    .visitor-nav-button:hover {
        color: white !important;
        transform: translateY(-2px);
        box-shadow: 0 18px 36px rgba(111, 165, 54, 0.36);
    }

    .visitor-main {
        min-height: calc(100vh - 82px);
    }

    @@media (max-width: 768px) {
        .visitor-navbar {
            height: auto;
            padding: 18px 24px;
            flex-direction: column;
            gap: 16px;
        }

        .visitor-nav {
            flex-wrap: wrap;
            justify-content: center;
        }
    }
</style>

<div class="visitor-layout">
    <header class="visitor-navbar">
        <NavLink class="visitor-brand" href="/homevisitor">
            <span class="visitor-brand-icon">🥗</span>
            <span class="visitor-brand-name">NutriRecipes</span>
        </NavLink>

        <nav class="visitor-nav">
            <NavLink class="visitor-nav-link" href="/homevisitor">
                Home
            </NavLink>

            <NavLink class="visitor-nav-link" href="/login">
                Login
            </NavLink>

            <NavLink class="visitor-nav-button" href="/register">
                Register
            </NavLink>
        </nav>
    </header>

    <main class="visitor-main">
        @Body
    </main>
</div>