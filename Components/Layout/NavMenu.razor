@using Microsoft.AspNetCore.Components.Authorization
@using app_nutri.Services

@inject AuthService AuthService
@inject NavigationManager NavigationManager

@rendermode InteractiveServer

<aside class="nutri-sidebar">

    <div class="brand-box">
            <span class="brand-icon">🥗</span>
            <span class="brand-text">
                <strong>YourRecipes</strong>
            </span>
    </div>

    <input type="checkbox" id="menu-toggle" class="menu-toggle" />
    <label for="menu-toggle" class="menu-toggle-label">
        ☰ Menu
    </label>

    <nav class="nav-section">

        <AuthorizeView Context="authContext">
            <Authorized>
                <div class="user-card">
                    <div>
                        <span>Bienvenue</span>
                        <strong>@(authContext.User.Identity?.Name ?? "Utilisateur")</strong>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="User">
            <Authorized>

                <NavLink class="nav-link" href="/recipes">
                    <span>Recipes</span>
                </NavLink>

                <NavLink class="nav-link" href="/create-recipe">
                    <span>Create Recipe</span>
                </NavLink>

                <NavLink class="nav-link" href="/favorites">
                    <span>Favorites</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="Admin">
            <Authorized>
                <p class="nav-title">Administration</p>

                <NavLink class="nav-link" href="/admin/dashboard">
                    <span>Dashboard</span>
                </NavLink>

                <NavLink class="nav-link" href="/admin/ingredients">
                    <span>Ingredients</span>
                </NavLink>

                <NavLink class="nav-link" href="/admin/users">
                    <span>Users</span>
                </NavLink>

                <NavLink class="nav-link" href="/admin/recipes">
                    <span>Recipes Admin</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView>
            <Authorized>
                <div class="logout-zone">
                    <button class="logout-btn" @onclick="Logout">
                        <span>Déconnexion</span>
                    </button>
                </div>
            </Authorized>

            <NotAuthorized>
                <p class="nav-title">Visiteur</p>

                <NavLink class="nav-link" href="/homevisitor">
                    <span class="nav-icon">🏠</span>
                    <span>Home</span>
                </NavLink>

                <NavLink class="nav-link" href="/login">
                    <span class="nav-icon">🔐</span>
                    <span>Connexion</span>
                </NavLink>

                <NavLink class="nav-link" href="/register">
                    <span class="nav-icon">📝</span>
                    <span>Inscription</span>
                </NavLink>
            </NotAuthorized>
        </AuthorizeView>

    </nav>
</aside>

@code {
    private void Logout()
    {
        AuthService.Logout();
        NavigationManager.NavigateTo("/login");
    }
}